# ─── App ───────────────────────────────────────────────────────────────────────
APP_ENV=production
APP_SECRET_KEY=change-me-to-a-long-random-secret
APP_ALLOWED_ORIGINS=https://your-domain.com,https://your-dashboard.com

# ─── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Database Direct Connection ────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:6543/postgres

# ─── WebSocket Security ────────────────────────────────────────────────────────
# REQUIRED: Generate a strong random key (64 hex chars)
# Run: python -c "import secrets; print(secrets.token_hex(32))"
WS_SECRET_KEY=your-64-char-hex-key-here

# ─── Data Bundle Encryption ────────────────────────────────────────────────────
# AES-256 key (base64-encoded 32 bytes)
# Run: python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
BUNDLE_ENCRYPTION_KEY=your-base64-aes-key-here

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://default:password@host:port
CACHE_TTL_SECONDS=300

# ─── AI Providers ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key
GROQ_API_KEY=your-groq-api-key
GEMINI_API_KEY=your-gemini-api-key

# ─── Google Maps ──────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ─── Cloudflare R2 (Bundle Storage) ──────────────────────────────────────────
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_ENDPOINT=https://your-account.r2.cloudflarestorage.com
R2_BUCKET=bundle

# ─── Firebase (Push Notifications) ────────────────────────────────────────────
# Base64-encoded service account JSON
FIREBASE_CREDENTIALS_BASE64=your-base64-encoded-firebase-credentials

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_API_KEY=change-me-admin-key

# ─── Pagination ────────────────────────────────────────────────────────────────
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
